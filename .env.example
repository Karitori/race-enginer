# Copy this file to .env and fill in your values

# Telemetry runtime
TELEMETRY_MODE=real
TELEMETRY_HOST=0.0.0.0
TELEMETRY_PORT=20777
TELEMETRY_FALLBACK_TO_MOCK=false
# Optional absolute path to parser2025.py if not using default repo locations.
# F1_25_PARSER_PATH=D:\Coding\Projects\f1-25-telemetry-application\src\parsers\parser2025.py

# LLM runtime (forced single local model)
LLM_PROVIDER=ollama
LLM_MODEL=nemotron-mini:4b
LLM_TEMPERATURE=0.2
# Optional role-specific temperature overrides:
# STRATEGY_TEMPERATURE=0.2
# ADVISOR_TEMPERATURE=0.2
# VOICE_TEMPERATURE=0.2

# Voice/audio runtime
VOICE_ENABLE_TTS=true
VOICE_TTS_BACKEND=kokoro
VOICE_SIMULATE_DELAY=true
# Kokoro backend (strictly local files only)
# VOICE_KOKORO_MODEL_PATH=D:\Coding\Models\kokoro\kokoro-v1.0.onnx
# VOICE_KOKORO_VOICES_PATH=D:\Coding\Models\kokoro\voices-v1.0.bin
# Voice is forced in code to af_sarah for consistent engineer identity.
# VOICE_KOKORO_LANG=en-us
# VOICE_KOKORO_SPEED=1.15
# VOICE_KOKORO_EXPRESSIVE=true
# Optional safety override (not recommended): skip subprocess stability probe.
# VOICE_KOKORO_SKIP_PROBE=false
# Optional style speeds:
# VOICE_KOKORO_SPEED_WARNING=1.25
# VOICE_KOKORO_SPEED_STRATEGY=1.12
# VOICE_KOKORO_SPEED_ENCOURAGEMENT=1.20
# VOICE_TTS_MAX_CHARS=220
VOICE_ENABLE_STT=false
VOICE_STT_BACKEND=parakeet
VOICE_STT_CONTROL_MODE=toggle
VOICE_STT_TOGGLE_DEFAULT_ON=false
VOICE_STT_LANGUAGE=en
VOICE_STT_TIMEOUT_SEC=4.0
VOICE_STT_PHRASE_LIMIT_SEC=6.0
VOICE_STT_AMBIENT_SEC=0.4
# PTT capture chunk length (records immediately while PTT is held):
# VOICE_STT_PTT_CHUNK_SEC=2.2
# Optional explicit microphone device index from speech_recognition list:
# VOICE_STT_MIC_INDEX=0
# STT detection tuning:
# VOICE_STT_DYNAMIC_ENERGY_THRESHOLD=true
# VOICE_STT_ENERGY_THRESHOLD=300
# STT runtime is forced to CPU in code for reliability.
# VOICE_STT_DEVICE=cpu
# Preferred local NVIDIA STT model (Parakeet).
VOICE_STT_PARAKEET_MODEL_PATH=models_assets/parakeet-tdt-0.6b-v3.nemo
# Optional shared fallback key for parakeet/canary model paths:
# VOICE_STT_MODEL_PATH=models_assets/parakeet-tdt-0.6b-v3.nemo
# Optional Canary backend (local model only):
# VOICE_STT_BACKEND=canary
# VOICE_STT_CANARY_MODEL_PATH=models_assets/canary-qwen-2.5b.nemo
# VOICE_STT_CANARY_PROMPT=Transcribe the following:
# VOICE_STT_CANARY_MAX_NEW_TOKENS=112
# Legacy fallback only (local Whisper Turbo):
# VOICE_STT_BACKEND=whisper
# VOICE_STT_WHISPER_MODEL=turbo
# VOICE_STT_WHISPER_BEAM_SIZE=1
# VOICE_STT_WHISPER_VAD_FILTER=false

# Standalone desktop overlay app (run separately via overlay_main.py)
OVERLAY_SETTINGS_FILE=.overlay_settings.json
# Initial values used on first run; after first launch values are persisted in OVERLAY_SETTINGS_FILE.
# OVERLAY_SERVER_HOST=127.0.0.1
# OVERLAY_SERVER_PORT=8000
# Optional runtime icon for the desktop overlay window (should be .ico on Windows)
# OVERLAY_ICON_PATH=assets/desktop_app_icon.ico
