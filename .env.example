# Copy this file to .env and fill in your values

# Telemetry runtime
TELEMETRY_MODE=real
TELEMETRY_HOST=0.0.0.0
TELEMETRY_PORT=20777
TELEMETRY_FALLBACK_TO_MOCK=false
# Optional absolute path to parser2025.py if not using default repo locations.
# F1_25_PARSER_PATH=D:\Coding\Projects\f1-25-telemetry-application\src\parsers\parser2025.py

# LLM runtime (forced single local model)
LLM_PROVIDER=ollama
LLM_MODEL=nemotron-mini:4b
LLM_TEMPERATURE=0.2
# Optional role-specific temperature overrides:
# STRATEGY_TEMPERATURE=0.2
# ADVISOR_TEMPERATURE=0.2
# VOICE_TEMPERATURE=0.2

# Voice/audio runtime
VOICE_ENABLE_TTS=true
VOICE_TTS_BACKEND=pocket
VOICE_SIMULATE_DELAY=true
# Pocket-TTS backend (strictly local files only) when VOICE_TTS_BACKEND=pocket
# VOICE_POCKET_CONFIG_PATH=D:\Coding\Models\pocket-tts\local_config.yaml
# VOICE_POCKET_AUDIO_PROMPT_PATH=D:\Coding\Models\pocket-tts\voice_prompt.wav
# VOICE_POCKET_DEVICE=cuda
# VOICE_POCKET_TEMP=0.7
# VOICE_POCKET_LSD_DECODE_STEPS=6
# VOICE_POCKET_NOISE_CLAMP=2.0
# VOICE_POCKET_EOS_THRESHOLD=-3.0
# VOICE_POCKET_MAX_TOKENS=180
# VOICE_POCKET_COPY_STATE=true
# VOICE_POCKET_TRUNCATE_PROMPT=true
VOICE_ENABLE_STT=false
VOICE_STT_BACKEND=whisper
VOICE_STT_LANGUAGE=en
VOICE_STT_TIMEOUT_SEC=4.0
VOICE_STT_PHRASE_LIMIT_SEC=6.0
VOICE_STT_AMBIENT_SEC=0.4
# Whisper local backend options (recommended)
# VOICE_STT_WHISPER_MODEL_PATH=D:\Coding\Models\whisper-large-v3-ct2
# VOICE_STT_WHISPER_DEVICE=cuda
# VOICE_STT_WHISPER_COMPUTE_TYPE=float16
# VOICE_STT_WHISPER_BEAM_SIZE=1
# VOICE_STT_WHISPER_VAD_FILTER=true

# Standalone desktop overlay app (run separately via overlay_main.py)
OVERLAY_SETTINGS_FILE=.overlay_settings.json
# Initial values used on first run; after first launch values are persisted in OVERLAY_SETTINGS_FILE.
# OVERLAY_SERVER_HOST=127.0.0.1
# OVERLAY_SERVER_PORT=8000
# Optional runtime icon for the desktop overlay window (should be .ico on Windows)
# OVERLAY_ICON_PATH=assets/desktop_app_icon.ico

# GEMINI_API_KEY=your_api_key_here
